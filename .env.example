# YT Clipper Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ElevenLabs Configuration (Optional - for AI voiceovers)
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_6f219f6d1d31c11bdffac8eaa1e7e322907519f6c66b330d

# YouTube URL (Optional - can also be passed via CLI or config.json)
# YOUTUBE_URL=https://www.youtube.com/watch?v=VIDEO_ID

# Optional: Default language for transcripts
# YOUTUBE_TRANSCRIPT_LANG=en

# Optional: Proxy for YouTube transcript API (to bypass IP blocking)
# Supported formats: http://host:port, http://user:pass@host:port, socks5://host:port
# Get residential proxies from providers like: Bright Data, Oxylabs, Smartproxy, etc.
# YOUTUBE_TRANSCRIPT_PROXY=http://user:pass@proxy-host:port

# Optional: Use standard HTTP/HTTPS proxy env vars (also works)
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port